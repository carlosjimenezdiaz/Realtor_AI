# Example .env for Realtor_AI
# Copy this to .env and fill in real values. Do NOT commit secrets.

# Required API keys
ANTHROPIC_API_KEY=your-anthropic-api-key
PERPLEXITY_API_KEY=your-perplexity-api-key
FIRECRAWL_API_KEY=your-firecrawl-api-key
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# State configuration
STATE_NAME=Florida
STATE_ABBREVIATION=FL
CITIES=Miami,Orlando,Tampa,Jacksonville,Fort Lauderdale
TIMEZONE=America/New_York
NEWSLETTER_NAME=Florida Realty Intel
STATE_REALTORS_URL=

# Optional / tuning
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=8192
REPORT_HOUR=8
REPORT_MINUTE=0
MESSAGE_DELAY_SECONDS=120
DEDUP_LOOKBACK_DAYS=7
DEDUP_HISTORY_FILE=data/seen_articles.json
LOG_LEVEL=INFO

# Quick restore:
# 1) Copy example: cp .env.example .env
# 2) Fill keys (API keys, telegram token/chat id)
# 3) For environment-specific files (e.g. .env.california), create a copy and edit
