# ─── Shared API Keys (same for all containers) ───────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here
FIRECRAWL_API_KEY=fc-your-key-here

# ─── Telegram (specific per state/channel) ───────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-texas-chat-id

# ─── State Configuration ──────────────────────────────────────────────────────
STATE_NAME=Texas
STATE_ABBREVIATION=TX
CITIES=Houston,Dallas,Austin,San Antonio,Fort Worth
TIMEZONE=America/Chicago
NEWSLETTER_NAME=Texas Realty Intel
STATE_REALTORS_URL=

# ─── Dedup file (keep state-scoped to avoid collisions) ──────────────────────
DEDUP_HISTORY_FILE=data/seen_articles_TX.json

# ─── Cron Schedule (cron syntax, UTC) ────────────────────────────────────────
# Mon–Fri 10:00 AM EST = 15:00 UTC
# Mon–Fri 10:00 AM EDT = 14:00 UTC
CRON_SCHEDULE=0 15 * * 1-5

# ─── Optional Tuning ─────────────────────────────────────────────────────────
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_MAX_TOKENS=8192
# MESSAGE_DELAY_SECONDS=120
# DEDUP_LOOKBACK_DAYS=7
# LOG_LEVEL=INFO
