# ─── Shared API Keys (same for all containers) ───────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here
FIRECRAWL_API_KEY=fc-your-key-here

# ─── Telegram (specific per state/channel) ───────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-florida-chat-id

# ─── State Configuration ──────────────────────────────────────────────────────
STATE_NAME=Florida
STATE_ABBREVIATION=FL
CITIES=Miami,Orlando,Tampa,Jacksonville,Fort Lauderdale
TIMEZONE=America/New_York
NEWSLETTER_NAME=Florida Realty Intel
STATE_REALTORS_URL=https://www.floridarealtors.org/news-media/news-articles/rss

# ─── Dedup file (keep state-scoped to avoid collisions) ──────────────────────
DEDUP_HISTORY_FILE=data/seen_articles_FL.json

# ─── Cron Schedule (cron syntax, UTC) ────────────────────────────────────────
# Mon–Fri 8:00 AM EST = 13:00 UTC
# Mon–Fri 8:00 AM EDT = 12:00 UTC
CRON_SCHEDULE=0 13 * * 1-5

# ─── Optional Tuning ─────────────────────────────────────────────────────────
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_MAX_TOKENS=8192
# MESSAGE_DELAY_SECONDS=120
# DEDUP_LOOKBACK_DAYS=7
# LOG_LEVEL=INFO
